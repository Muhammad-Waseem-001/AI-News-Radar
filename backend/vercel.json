{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/cron/ingest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/v1/cron/digest",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
