# Core app settings
# Supabase transaction-pooler connection string example:
# postgresql+psycopg://postgres.<project_ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres.<project_ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
AUTO_CREATE_TABLES=true
RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml,https://techcrunch.com/category/artificial-intelligence/feed/
MAX_ARTICLES_PER_FEED=25
INGEST_INTERVAL_MINUTES=30
DIGEST_HOUR_24=18
TIMEZONE=Asia/Karachi
ENABLE_LOCAL_SCHEDULER=false

# AI settings (Google Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Gmail settings (App Password required)
GMAIL_USERNAME=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
ALERT_RECIPIENTS=alerts@example.com
DIGEST_RECIPIENTS=digest@example.com
ALERT_SENTIMENT_THRESHOLD=-0.6

# Protect cron endpoints (required for Vercel cron in production)
CRON_SECRET=replace_with_long_random_secret

# Frontend origin(s) - add deployed frontend URL too
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
